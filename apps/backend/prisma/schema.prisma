// ============================================
// FinishVision — Prisma Schema
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  OWNER
  ADMIN
  ESTIMATOR
  VIEWER
}

enum ProjectStatus {
  BIDDING
  AWARDED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum SubscriptionTier {
  STARTER
  PROFESSIONAL
  BUSINESS
  ENTERPRISE
}

enum FileStatus {
  UPLOADING
  PROCESSING
  READY
  ERROR
}

enum SheetType {
  FLOOR_PLAN
  DOOR_SCHEDULE
  WINDOW_SCHEDULE
  ELEVATION
  DETAIL
  COVER
  OTHER
}

// ============================================
// COMPANY (Tenant)
// ============================================

model Company {
  id               String           @id @default(uuid())
  name             String
  subscriptionTier SubscriptionTier @default(STARTER)
  address          String?
  phone            String?
  website          String?
  logoUrl          String?
  defaultMarkup    Decimal          @default(0) @db.Decimal(5, 2)
  defaultTaxRate   Decimal          @default(0) @db.Decimal(5, 4)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  users    User[]
  projects Project[]

  @@map("companies")
}

// ============================================
// USER
// ============================================

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole  @default(ESTIMATOR)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  companyId    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([email])
  @@map("users")
}

// ============================================
// PROJECT
// ============================================

model Project {
  id                String        @id @default(uuid())
  companyId         String
  name              String
  address           String?
  city              String?
  state             String?
  zipCode           String?
  status            ProjectStatus @default(BIDDING)
  bidDate           DateTime?
  generalContractor String?
  architect         String?
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  buildings    Building[]
  blueprints   Blueprint[]
  takeoffItems TakeoffItem[]
  estimates    Estimate[]
  reports      Report[]

  @@index([companyId])
  @@index([status])
  @@map("projects")
}

// ============================================
// BUILDING
// ============================================

model Building {
  id        String   @id @default(uuid())
  projectId String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  floors  Floor[]

  @@index([projectId])
  @@map("buildings")
}

// ============================================
// FLOOR
// ============================================

model Floor {
  id         String   @id @default(uuid())
  buildingId String
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  units    Unit[]

  @@index([buildingId])
  @@map("floors")
}

// ============================================
// UNIT
// ============================================

model Unit {
  id        String   @id @default(uuid())
  floorId   String
  name      String
  unitType  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  floor Floor  @relation(fields: [floorId], references: [id], onDelete: Cascade)
  rooms Room[]

  @@index([floorId])
  @@map("units")
}

// ============================================
// ROOM
// ============================================

model Room {
  id        String   @id @default(uuid())
  unitId    String
  name      String
  roomType  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId])
  @@map("rooms")
}

// ============================================
// BLUEPRINT (uploaded PDF file)
// ============================================

model Blueprint {
  id           String     @id @default(uuid())
  projectId    String
  uploadedById String
  originalName String
  storagePath  String
  fileSize     Int
  mimeType     String     @default("application/pdf")
  status       FileStatus @default(UPLOADING)
  pageCount    Int        @default(0)
  errorMessage String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sheets  Sheet[]

  @@index([projectId])
  @@index([status])
  @@map("blueprints")
}

// ============================================
// SHEET (individual page from a blueprint PDF)
// ============================================

model Sheet {
  id            String    @id @default(uuid())
  blueprintId   String
  pageNumber    Int
  sheetName     String?
  sheetType     SheetType @default(OTHER)
  thumbnailPath String?
  imagePath     String?
  width         Int?      @db.Integer
  height        Int?      @db.Integer
  dpi           Int?      @db.Integer
  scaleText     String?
  scaleFactor   Float?
  ocrText       String?   @db.Text
  ocrCompleted  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  blueprint   Blueprint    @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  annotations Annotation[]
  aiJobs      AiJob[]
  aiDetections AiDetection[]

  @@unique([blueprintId, pageNumber])
  @@index([blueprintId])
  @@index([sheetType])
  @@map("sheets")
}

// ============================================
// ANNOTATION (measurements, markers on sheets)
// ============================================

enum AnnotationType {
  CALIBRATION
  MEASUREMENT
  MARKER
  NOTE
}

model Annotation {
  id          String         @id @default(uuid())
  sheetId     String
  createdById String
  type        AnnotationType
  label       String?
  data        Json // Stores coordinates, points, dimensions etc.
  color       String?        @default("#2563EB")
  visible     Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  sheet Sheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@index([sheetId])
  @@index([type])
  @@map("annotations")
}

// ============================================
// TAKEOFF CATEGORY (finish carpentry categories)
// ============================================

enum TakeoffMeasureType {
  COUNT
  LINEAR
  AREA
}

model TakeoffCategory {
  id          String             @id @default(uuid())
  companyId   String? // null = system default
  name        String
  code        String // e.g. "INT_DOOR", "EXT_DOOR", "WINDOW"
  color       String             @default("#2563EB")
  icon        String?
  measureType TakeoffMeasureType @default(COUNT)
  unit        String             @default("ea") // ea, lf, sf
  sortOrder   Int                @default(0)
  isSystem    Boolean            @default(false)
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  items        TakeoffItem[]
  aiDetections AiDetection[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([isSystem])
  @@map("takeoff_categories")
}

// ============================================
// TAKEOFF ITEM (individual detected/counted item)
// ============================================

enum TakeoffSource {
  MANUAL
  AI_DETECTED
  AI_CONFIRMED
}

model TakeoffItem {
  id          String        @id @default(uuid())
  projectId   String
  categoryId  String
  sheetId     String? // which sheet it was taken from
  roomId      String? // which room it belongs to
  createdById String
  source      TakeoffSource @default(MANUAL)
  label       String?
  description String?
  quantity    Float         @default(1)
  unit        String        @default("ea")
  // Measurement data
  length      Float? // for linear items (inches)
  width       Float? // for area items (inches)
  area        Float? // for area items (sq inches)
  // Location on blueprint
  coordinates Json? // {points: [{x,y}], type: 'point'|'polyline'|'polygon'}
  // Metadata
  confidence  Float? // AI confidence score 0-1
  verified    Boolean       @default(false)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  project  Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  category TakeoffCategory @relation(fields: [categoryId], references: [id])

  @@index([projectId])
  @@index([categoryId])
  @@index([sheetId])
  @@index([roomId])
  @@index([source])
  @@map("takeoff_items")
}

// ============================================
// TAKEOFF SUMMARY (aggregated per project)
// ============================================

model TakeoffSummary {
  id         String   @id @default(uuid())
  projectId  String
  categoryId String
  roomId     String?
  totalCount Float    @default(0)
  totalLF    Float    @default(0)
  totalSF    Float    @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([projectId, categoryId, roomId])
  @@index([projectId])
  @@map("takeoff_summaries")
}

// ============================================
// COST ITEM (material/product cost database)
// ============================================

model CostItem {
  id          String   @id @default(uuid())
  companyId   String? // null = system default
  categoryId  String? // links to TakeoffCategory
  name        String
  description String?
  sku         String?
  unit        String   @default("ea") // ea, lf, sf, set
  unitCost    Decimal  @db.Decimal(10, 2)
  supplier    String?
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assemblyItems AssemblyItem[]

  @@index([companyId])
  @@index([categoryId])
  @@map("cost_items")
}

// ============================================
// LABOR RATE (labor cost per activity)
// ============================================

model LaborRate {
  id           String   @id @default(uuid())
  companyId    String? // null = system default
  name         String // e.g. "Door Installation", "Base Trim Install"
  description  String?
  unit         String   @default("ea") // ea, lf, sf
  ratePerUnit  Decimal  @db.Decimal(10, 2) // labor cost per unit
  hoursPerUnit Decimal  @db.Decimal(8, 4) // estimated hours per unit
  hourlyRate   Decimal  @db.Decimal(8, 2) // base hourly rate
  isSystem     Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assemblyItems AssemblyItem[]

  @@index([companyId])
  @@map("labor_rates")
}

// ============================================
// ASSEMBLY (template: material + labor bundle)
// ============================================

model Assembly {
  id          String   @id @default(uuid())
  companyId   String? // null = system default
  categoryId  String? // links to TakeoffCategory
  name        String // e.g. "Interior Door Complete Install"
  description String?
  unit        String   @default("ea")
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items         AssemblyItem[]
  estimateLines EstimateLine[]

  @@index([companyId])
  @@index([categoryId])
  @@map("assemblies")
}

// ============================================
// ASSEMBLY ITEM (line within an assembly)
// ============================================

enum AssemblyItemType {
  MATERIAL
  LABOR
}

model AssemblyItem {
  id          String           @id @default(uuid())
  assemblyId  String
  type        AssemblyItemType
  costItemId  String? // for MATERIAL type
  laborRateId String? // for LABOR type
  name        String
  unit        String           @default("ea")
  quantity    Decimal          @db.Decimal(10, 4) // qty per 1 assembly unit
  unitCost    Decimal          @db.Decimal(10, 2)
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  assembly  Assembly   @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  costItem  CostItem?  @relation(fields: [costItemId], references: [id])
  laborRate LaborRate? @relation(fields: [laborRateId], references: [id])

  @@index([assemblyId])
  @@map("assembly_items")
}

// ============================================
// ESTIMATE
// ============================================

enum EstimateStatus {
  DRAFT
  REVIEW
  APPROVED
  SENT
  ACCEPTED
  REJECTED
}

model Estimate {
  id            String         @id @default(uuid())
  projectId     String
  companyId     String
  createdById   String
  name          String
  version       Int            @default(1)
  status        EstimateStatus @default(DRAFT)
  subtotal      Decimal        @default(0) @db.Decimal(12, 2)
  markupPercent Decimal        @default(0) @db.Decimal(5, 2)
  markupAmount  Decimal        @default(0) @db.Decimal(12, 2)
  taxPercent    Decimal        @default(0) @db.Decimal(5, 4)
  taxAmount     Decimal        @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal        @default(0) @db.Decimal(12, 2)
  notes         String?        @db.Text
  validUntil    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lines   EstimateLine[]
  reports Report[]

  @@index([projectId])
  @@index([companyId])
  @@index([status])
  @@map("estimates")
}

// ============================================
// ESTIMATE LINE (individual line in estimate)
// ============================================

model EstimateLine {
  id            String   @id @default(uuid())
  estimateId    String
  assemblyId    String?
  takeoffItemId String?
  categoryCode  String?
  description   String
  unit          String   @default("ea")
  quantity      Decimal  @db.Decimal(10, 4)
  materialCost  Decimal  @default(0) @db.Decimal(10, 2)
  laborCost     Decimal  @default(0) @db.Decimal(10, 2)
  totalCost     Decimal  @default(0) @db.Decimal(10, 2)
  sortOrder     Int      @default(0)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  estimate Estimate  @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  assembly Assembly? @relation(fields: [assemblyId], references: [id])

  @@index([estimateId])
  @@index([assemblyId])
  @@map("estimate_lines")
}

// ============================================
// REPORT
// ============================================

enum ReportType {
  TAKEOFF_SUMMARY
  ESTIMATE_SUMMARY
  PROPOSAL
}

enum ReportFormat {
  PDF
  CSV
  JSON
}

model Report {
  id          String       @id @default(uuid())
  projectId   String
  estimateId  String?
  companyId   String
  createdById String
  type        ReportType
  format      ReportFormat @default(PDF)
  name        String
  storagePath String?
  fileSize    Int?
  metadata    Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  estimate Estimate? @relation(fields: [estimateId], references: [id])

  @@index([projectId])
  @@index([companyId])
  @@map("reports")
}

// ============================================
// AI DETECTION
// ============================================

enum AiJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum DetectionStatus {
  PENDING    // AI detected, awaiting human review
  ACCEPTED   // User accepted the detection
  REJECTED   // User rejected the detection
  MODIFIED   // User accepted with modifications
}

enum DetectionType {
  DOOR_SINGLE
  DOOR_DOUBLE
  DOOR_SLIDING
  DOOR_POCKET
  DOOR_BIFOLD
  DOOR_METAL
  WINDOW
  CLOSET
  CABINET_RUN
  ROOM_LABEL
  DIMENSION
  SCHEDULE_ENTRY
  SYMBOL_OTHER
}

model AiJob {
  id           String      @id @default(uuid())
  sheetId      String
  projectId    String
  companyId    String
  triggeredById String
  status       AiJobStatus @default(QUEUED)
  pipelineSteps Json?      // tracks which steps completed
  ocrText      String?     @db.Text
  ocrMetadata  Json?       // structured OCR results (rooms, dims, tags)
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  processingMs Int?        // total processing time
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  sheet      Sheet        @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  detections AiDetection[]

  @@index([sheetId])
  @@index([projectId])
  @@index([status])
  @@map("ai_jobs")
}

model AiDetection {
  id             String          @id @default(uuid())
  aiJobId        String
  sheetId        String
  projectId      String
  type           DetectionType
  label          String          // human-readable label, e.g. "Interior Single Door"
  confidence     Decimal         @db.Decimal(5, 4) // 0.0000 - 1.0000
  boundingBox    Json            // { x, y, width, height } in pixels
  coordinates    Json?           // { points: [{x,y}] } for polygons
  metadata       Json?           // extra data (dimensions, tag text, schedule row)
  status         DetectionStatus @default(PENDING)
  reviewedById   String?
  reviewedAt     DateTime?
  reviewNotes    String?
  takeoffItemId  String?         // linked takeoff item if accepted
  categoryId     String?         // suggested takeoff category
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  aiJob    AiJob          @relation(fields: [aiJobId], references: [id], onDelete: Cascade)
  sheet    Sheet          @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  category TakeoffCategory? @relation(fields: [categoryId], references: [id])

  @@index([aiJobId])
  @@index([sheetId])
  @@index([status])
  @@index([type])
  @@map("ai_detections")
}
